# ─────────────────────────────────────────────
# Aurora – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Pinata (IPFS pinning service) ────────────
# Get these from https://app.pinata.cloud/keys
VITE_ENABLE_PINATA=false
VITE_PINATA_JWT=
VITE_PINATA_API_KEY=
VITE_PINATA_API_SECRET=

# Your dedicated Pinata gateway (Project → Gateways in the Pinata dashboard)
# Format: https://<your-subdomain>.mypinata.cloud/ipfs/
# Fallback to public gateway when left empty
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ── Web3.Storage / IPFS (optional fallback) ──
# Only needed when VITE_ENABLE_IPFS=true
VITE_ENABLE_IPFS=false
VITE_IPFS_EMAIL=

# ── Feature flags ────────────────────────────
# Local storage is always on; set the others to
# "true" only after configuring the service above
VITE_ENABLE_LOCAL_STORAGE=true
